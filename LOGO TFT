void setup() {
  Serial.begin(115200);

  // 1. Inicializar pantalla
  tft.init();
  tft.setRotation(0); // 0 es vertical (Portrait)
  
  // 2. Encender la retroiluminación (IMPORTANTE en el CYD)
  // El pin 21 controla los LEDs de fondo en tu modelo
  pinMode(21, OUTPUT);
  digitalWrite(21, HIGH);

  // 3. Limpiar pantalla en negro
  tft.fillScreen(TFT_BLACK);

  // 4. Dibujar el logo
  // Cálculos para centrar: 
  // Pantalla es 240 ancho, Logo es 198 -> (240-198)/2 = 21 (X)
  // Pantalla es 320 alto, Logo es 161 -> (320-161)/2 = 80 (Y)
  
  int x = 21; 
  int y = 80;
  int ancho = 198;
  int alto = 161;

  Serial.println("Mostrando logo de seguridad...");
  
  // Función: drawBitmap(x, y, data, ancho, alto, color)
  tft.drawBitmap(x, y, epd_bitmap_IMG_6858_198x161, ancho, alto, TFT_WHITE);

  // Opcional: Agregar un texto debajo del logo
  tft.setTextColor(TFT_WHITE);
  tft.setTextDatum(MC_DATUM); // Centrar texto
  tft.drawString("SISTEMA ACTIVO", 120, 260, 4); 
}

